# ============================================================================
# ioQuake3-PS4 .gitignore
# ============================================================================

# Build output
build/
*.o
*.i
*.elf
*.oelf
*.pkg
*.gp4
eboot.bin
test_piglet.*
test.gp4

# Generated metadata (rebuilt by Makefile)
sce_sys/param.sfo

# PS4 proprietary modules - NOT redistributable (Sony IP)
# libSceShaccVSH.sprx is the runtime GLSL compiler (devkit-only, not on retail FW)
# Users must obtain it from a devkit firmware PUP
sce_module/libSceShaccVSH.sprx
sce_module/libScePigletv2VSH.sprx
sce_module/libScePrecompiledShaders.sprx
sce_module/*.sprx
sce_module/*.prx

# Game data - copyrighted Quake III Arena assets
# Users must supply their own legally obtained .pk3 files
baseq3/*.pk3
missionpack/*.pk3

# OpenOrbis toolchain (external dependency, not part of repo)
# Pointed to by $OO_PS4_TOOLCHAIN env var

# AI / Claude Code
.claude/
CLAUDE.md

# IDE / editor files
.vs/
.vscode/
*.suo
*.user
*.sln
*.vcxproj*
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# clangd / LSP (auto-generated by clang-based tooling)
compile_commands.json
.clangd
.cache/

# ctags / cscope index files
tags
TAGS
cscope.out
cscope.in.out
cscope.po.out

# OS junk
*.tmp
*.bak
*.log
