# ============================================================================
# ioQuake3-PS4 .gitignore
# ============================================================================

# Build output
build/
*.i
*.elf
*.oelf
*.pkg
*.zip
*.gp4
eboot.bin
test_piglet.*
test.gp4

# Object files — except ps4_crt1.o, which is a checked-in link-time input
# (PS4 C runtime startup, prepended to the link by the Makefile)
*.o
!ps4_crt1.o

# Generated metadata (rebuilt by Makefile)
sce_sys/param.sfo

# PS4 proprietary modules - NOT redistributable (Sony IP)
# libSceShaccVSH.sprx is the runtime GLSL compiler (devkit-only, not on retail FW)
# Users must obtain it from a devkit firmware PUP
sce_module/libSceShaccVSH.sprx
sce_module/libScePigletv2VSH.sprx
sce_module/libScePrecompiledShaders.sprx
sce_module/*.sprx
sce_module/*.prx

# Game data - copyrighted Quake III Arena assets
# Users must supply their own legally obtained .pk3 files
baseq3/*.pk3
missionpack/*.pk3

# Third-party libraries not used by the PS4 build
# (Makefile only links jpeg-9f and zlib-1.3.1)
code/thirdparty/SDL2-2.32.8/
code/thirdparty/curl-8.15.0/
code/thirdparty/libogg-1.3.6/
code/thirdparty/libvorbis-1.3.7/
code/thirdparty/openal-soft-1.24.3/
code/thirdparty/opus-1.5.2/
code/thirdparty/opusfile-0.12/

# OpenOrbis toolchain (external dependency, not part of repo)
# Pointed to by $OO_PS4_TOOLCHAIN env var

# AI / Claude Code
.claude/
CLAUDE.md

# IDE / editor files
.vs/
.vscode/
*.suo
*.user
*.sln
*.vcxproj*
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# clangd / LSP (auto-generated by clang-based tooling)
compile_commands.json
.clangd
.cache/

# ctags / cscope index files
tags
TAGS
cscope.out
cscope.in.out
cscope.po.out
cscope.files

# OS junk
*.tmp
*.bak
*.log
